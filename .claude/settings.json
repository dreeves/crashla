{
  "permissions": {
    "allow": [
      "WebFetch(domain:waymo.com)",
      "WebFetch(domain:arxiv.org)",
      "WebSearch",
      "WebFetch(domain:www.cpuc.ca.gov)",
      "WebFetch(domain:ourworldindata.org)",
      "WebFetch(domain:catalog.ourworldindata.org)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)"
    ],
    "deny": [
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git add)",
      "Bash(git add *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git reset)",
      "Bash(git reset *)",
      "Bash(git rebase)",
      "Bash(git rebase *)",
      "Bash(git merge)",
      "Bash(git merge *)",
      "Bash(git restore)",
      "Bash(git restore *)",
      "Bash(git stash)",
      "Bash(git stash *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git tag)",
      "Bash(git tag *)",
      "Bash(git checkout)",
      "Bash(git checkout *)",
      "Bash(git switch)",
      "Bash(git switch *)",
      "Bash(git cherry-pick)",
      "Bash(git cherry-pick *)",
      "Bash(git revert)",
      "Bash(git revert *)"
    ]
  }
}
